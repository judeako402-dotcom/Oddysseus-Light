# ── Odysseus Server Config ──────────────────────────────────
PORT=4000

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated allowed origins. Use * for any (not recommended).
CORS_ORIGIN=http://localhost:5173

# ── Auth (Optional) ─────────────────────────────────────────
# Set a token to protect POST routes. If unset, no auth required (local dev).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ODYSSEUS_TOKEN=

# ── Free AI Providers ───────────────────────────────────────
# OpenAI-compatible endpoint. Get a free key from:
#   OpenRouter: https://openrouter.ai/keys
#   Groq:       https://console.groq.com/keys
#
AI_PROVIDER_URL=https://openrouter.ai/api/v1
AI_PROVIDER_KEY=sk-or-v1-your-key-here
AI_MODEL=meta-llama/llama-3.1-8b-instruct

# ── Local Services ──────────────────────────────────────────
N8N_WEBHOOK_URL=http://localhost:5678/webhook-test/odysseus-command
N8N_TIMEOUT_MS=5000

OPENCODE_CONFIG_PATH=
